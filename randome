.timeline {
    margin-top: 2rem;
    position: relative;
  }
  
  .timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: #333; /* Timeline line color */
  }
  
  .timeline-item {
    position: relative;
    width: 50%;
    padding: 2rem;
    box-sizing: border-box;
  }
  
  .timeline-item:nth-child(odd) {
    left: 0;
  }
  
  .timeline-item:nth-child(even) {
    left: 50%;
  }
  
  .timeline-icon {
