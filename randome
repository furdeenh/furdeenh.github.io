  /* Add these styles to your existing style.css */
  
  .header-experience {
    background-color: #f0f0f0; /* Light grey background */
    padding: 20px 0;
    text-align: center;
    margin-bottom: 30px;
  }
  
  .experience-section {
    margin: 0 10rem; /* Adjust the margin as necessary */
  }
  
  .experience-entry {
    background: #ffffff;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    padding: 20px;
    margin-bottom: 20px;
  }
  
  .experience-entry h2 {
    color: #333333; /* Dark grey color */
    margin-bottom: 10px;
  }
  
  .experience-entry h3 {
    color: #666666; /* Medium grey color */
    margin-bottom: 10px;
  }
  
  .experience-entry ul {
    margin-left: 20px;
  }
  
  .experience-entry ul li {
    margin-bottom: 10px;
  }
  
  .date-location {
    text-align: right;
    margin-top: 10px;
    font-style: italic;
  }
  
  .date-location span {
    font-weight: bold;
    font-style: normal;
